within ThermofluidStream.Idealized.EnergyFlow;
package Tests
  extends Modelica.Icons.ExamplesPackage;

  annotation(Documentation(info="<html>
  <p>
    This package contains tests of the energy flow connector.
  </p>
  <p>
    It tests the compatibility of <code>EnergyFlowInput/Output</code> and <code>RealInput/Output</code> connectors.<br>
    Further note the distinction between signal flow and the physical positive direction of energy flow.
  </p>
</html>"));
end Tests;
